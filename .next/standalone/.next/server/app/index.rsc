2:T616,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How is Cheetah AGI different from a typical AI consultancy?","acceptedAnswer":{"@type":"Answer","text":"Most consultancies sell decks. We ship systems. Every engagement starts with a 30-day paid diagnostic where we either prescribe a build plan or tell you to walk away. We measure ourselves on revenue impact, not deliverables shipped — and we publish our methodology openly so clients know what they're paying for."}},{"@type":"Question","name":"Do you work with companies outside India?","acceptedAnswer":{"@type":"Answer","text":"Yes. We're headquartered in Lucknow, India and operate globally. Our voice agent product (Callio) is India-first because of telecom integration — but consulting, automation, and funnel work happens with clients across North America, Europe, and Southeast Asia."}},{"@type":"Question","name":"What's the minimum engagement size?","acceptedAnswer":{"@type":"Answer","text":"The 30-day diagnostic starts at ₹3L (about USD 3,600). Retainer engagements typically start at ₹2L/month. For outcome-based work, we evaluate fit case-by-case."}},{"@type":"Question","name":"Do you build with specific AI vendors or are you tool-agnostic?","acceptedAnswer":{"@type":"Answer","text":"Tool-agnostic by default. We use OpenAI, Anthropic, Google, ElevenLabs, and open-source models depending on the workflow. Our role is to pick the right tool — not to lock you into one we get a kickback from. We disclose any partnerships upfront."}}]}0:["boK7JH1n2IoPGt8p4oLeJ",[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",true],["",{"children":["__PAGE__",{},[["$L1",[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],["$","$L3",null,{}],["$","section",null,{"className":"section","children":["$","div",null,{"className":"container-tight","children":["$","div",null,{"className":"grid lg:grid-cols-12 gap-12 items-end","children":[["$",